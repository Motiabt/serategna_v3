# ─── Serategna deployment (docker compose) ───────────────────────────────────
# Copy to `.env` next to docker-compose.yml before `docker compose up`.

# Database
POSTGRES_USER=serategna
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=serategna

# Auth secrets — generate with: openssl rand -hex 48
JWT_ACCESS_SECRET=replace-with-64+char-random-string
JWT_REFRESH_SECRET=replace-with-another-64+char-random-string

# Public origin(s) the web app is served from (comma separated)
CORS_ORIGINS=http://localhost:8080

# Web published port
WEB_PORT=8080

# Seed demo data on first boot (set false for a clean production DB)
SEED_ON_START=true

# Keep false in production — when true the API returns OTP codes in responses.
OTP_DEV_MODE=false
