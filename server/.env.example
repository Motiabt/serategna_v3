# ─── Serategna API environment ───────────────────────────────────────────────
# Copy to `.env` and adjust. Defaults below run with zero external services.

NODE_ENV=development
PORT=4000

# Datasource. Default = SQLite (zero-config dev). For production use Postgres:
#   DATABASE_URL="postgresql://user:pass@host:5432/serategna?schema=public"
DATABASE_URL="file:./dev.db"

# Auth secrets — REPLACE in production with long random strings.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=900            # seconds (15 min)
REFRESH_TOKEN_TTL=2592000       # seconds (30 days)

# CORS — comma separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Marketplace economics (basis points where noted).
TAKE_RATE_HOME=0.07             # 7% home services
TAKE_RATE_DELIVERY=0.10         # 10% delivery
GUARANTEE_RESERVE_RATE=0.01     # 1% of job value (carved from take-rate)
TIER0_JOB_CAP=5                 # max jobs before Fayda required
TIER0_GROSS_CAP=4000            # max gross ETB before Fayda required

# OTP — in dev, OTPs are returned in the API response and logged. Wire an
# SMS gateway here for production.
OTP_DEV_MODE=true

# Require admins to pass TOTP 2FA (authenticator app) for the admin console.
# Recommended true in production. Admins enrol via POST /api/auth/2fa/setup+enable.
REQUIRE_ADMIN_2FA=false

# ─── Integrations (all optional; the app runs with safe fallbacks) ────────────
# Payments: 'mock' (instant, dev) or 'chapa' (licensed PSO, hosted checkout).
PAYMENT_ADAPTER=mock
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=
CHAPA_CALLBACK_URL=
PAYOUT_DAILY_CAP=10000

# Maps: server-side flag for the admin integrations panel. The web app reads
# VITE_GOOGLE_MAPS_KEY (see web/.env). Leave unset to use the fallback map.
GOOGLE_MAPS_ENABLED=

# ─── SMS / OTP delivery ───────────────────────────────────────────────────────
# SMS_PROVIDER: 'console' (dev — logs the code), 'ethiotelecom' (Ethio Telecom
# bulk/enterprise SMS), 'http' (generic JSON gateway), or 'twilio'.
SMS_PROVIDER=ethiotelecom
#   ethiotelecom provider (numbers auto-normalised to 2519XXXXXXXX):
ETHIOTEL_SMS_URL=                # bulk-SMS POST endpoint from your Ethio Telecom packet
ETHIOTEL_SENDER=Serategna        # approved sender id / short code (e.g. 8294)
ETHIOTEL_TOKEN=                  # API token (preferred) — sent as Bearer
ETHIOTEL_USERNAME=               # OR username/password if your account uses basic auth
ETHIOTEL_PASSWORD=
#   http provider (AfroMessage / Geez SMS):
SMS_GATEWAY_URL=                 # POST endpoint; receives {to,from,message,text}
SMS_API_KEY=                     # sent as: Authorization: Bearer <key>
SMS_SENDER=Serategna             # sender id / from number
#   twilio provider:
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
# (SMS_SENDER above is the Twilio 'from' number when SMS_PROVIDER=twilio)

# Other messaging channels (seams; fall back to no-op until wired)
FCM_SERVER_KEY=
TELEGRAM_BOT_TOKEN=

# ─── Observability ────────────────────────────────────────────────────────────
# Forward 500-class errors to an external collector (Sentry tunnel, webhook…).
# Leave unset to just log structured JSON to stdout.
ERROR_WEBHOOK=

# Identity: Fayda / MOSIP API (manual review fallback active when unset)
MOSIP_API_KEY=
