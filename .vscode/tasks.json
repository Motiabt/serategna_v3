{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install all",
      "type": "shell",
      "command": "npm run install:all",
      "problemMatcher": []
    },
    {
      "label": "Setup database (generate + push + seed)",
      "type": "shell",
      "command": "npm run setup",
      "options": { "cwd": "${workspaceFolder}/server" },
      "problemMatcher": []
    },
    {
      "label": "API: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/server" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Web: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/web" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run all (API + Web)",
      "dependsOn": ["API: dev", "Web: dev"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
